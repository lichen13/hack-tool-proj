# /hack_tool_proj/src/main.py
from scanner.main import show_scanner_menu
from logger import Logger
from path_finder import FILES
import os

def show_menu():
    with open(FILES["menu_template"], "r") as f:
        print(f.read())

    optionTaken = input("[ ] Select an option : ")

    if optionTaken == "0":
        exit()
    elif optionTaken == "1":
        show_scanner_menu()
    else:
        print("\nInvalid option.")
        exit()

if __name__ == "__main__":
    if os.name == "posix":
        os.system("clear")
        show_menu()
    else:
        print("HackToolProj only works on Linux (POSIX).")
        exit()
